{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"$id": "https://tbtop.dev/contracts/structure.schema.json",
	"version": 1,
	"title": "Tabletop wire structure grammar v1",
	"$ref": "#/$defs/node",
	"$defs": {
		"node": {
			"type": "object",
			"required": ["kind", "options", "meta"],
			"properties": {
				"kind": { "type": "string", "minLength": 1 },
				"name": { "type": "string" },
				"options": { "$ref": "#/$defs/containerOptions" },
				"meta": {
					"type": "object",
					"properties": {
						"hiddenIf": { "$ref": "#/$defs/condition" },
						"disabledIf": { "$ref": "#/$defs/condition" }
					}
				}
			},
			"additionalProperties": false,
			"allOf": [
				{
					"if": { "properties": { "kind": { "const": "action" } } },
					"then": {
						"properties": {
							"options": {
								"required": ["spec"],
								"properties": { "spec": { "$ref": "#/$defs/actionSpec" } }
							}
						}
					}
				},
				{
					"if": { "properties": { "kind": { "const": "form" } } },
					"then": {
						"properties": {
							"options": { "required": ["name", "children"] }
						}
					}
				},
				{
					"if": { "properties": { "kind": { "const": "table" } } },
					"then": {
						"properties": {
							"options": {
								"required": ["name", "columns"],
								"properties": {
									"columns": { "$ref": "#/$defs/columns" },
									"pagination": { "$ref": "#/$defs/pagination" },
									"rowClick": { "type": "string" },
									"reorder": {
										"type": "object",
										"required": ["column"],
										"properties": {
											"column": { "type": "string" }
										},
										"additionalProperties": false
									},
									"tabs": {
										"type": "array",
										"items": { "$ref": "#/$defs/tableTab" }
									}
								}
							}
						}
					}
				},
				{
					"if": { "properties": { "kind": { "const": "collapsible" } } },
					"then": {
						"properties": {
							"options": {
								"required": ["label"],
								"properties": {
									"label": { "type": "string" },
									"collapsed": { "type": "boolean" }
								}
							}
						}
					}
				},
				{
					"if": { "properties": { "kind": { "const": "actionGroup" } } },
					"then": {
						"properties": {
							"options": {
								"required": ["label"],
								"properties": {
									"label": { "type": "string" },
									"as": { "type": "string", "enum": ["buttons", "dropdown"] }
								}
							}
						}
					}
				},
				{
					"if": { "properties": { "kind": { "const": "mediaLibrary" } } },
					"then": {
						"properties": {
							"options": { "type": "object" }
						}
					}
				},
				{
					"if": { "properties": { "kind": { "const": "media" } } },
					"then": {
						"properties": {
							"options": {
								"properties": {
									"multiple": { "type": "boolean" },
									"accept": { "type": "array", "items": { "type": "string" } }
								}
							}
						}
					}
				},
				{
					"if": { "properties": { "kind": { "const": "upload" } } },
					"then": {
						"properties": {
							"options": {
								"properties": {
									"accept": { "type": "string" },
									"maxSize": { "type": "integer", "minimum": 0 },
									"disk": { "type": "string" },
									"directory": { "type": "string" },
									"profile": { "type": "string" },
									"visibility": {
										"type": "string",
										"enum": ["public", "private"]
									},
									"image": {
										"type": "object",
										"properties": {
											"convertTo": {
												"type": "string",
												"enum": ["webp", "jpeg", "png"]
											},
											"quality": {
												"type": "integer",
												"minimum": 1,
												"maximum": 100
											}
										}
									}
								}
							}
						}
					}
				},
				{
					"if": {
						"properties": {
							"kind": {
								"enum": ["navMenu", "userMenu", "logo", "localeSwitcher", "spacer"]
							}
						}
					},
					"then": {
						"properties": {
							"options": {
								"additionalProperties": false,
								"properties": {}
							}
						}
					}
				},
				{
					"if": {
						"properties": { "kind": { "const": "flex" } }
					},
					"then": {
						"properties": {
							"options": {
								"required": ["direction", "children"],
								"properties": {
									"direction": {
										"type": "string",
										"enum": ["row", "col"]
									},
									"justify": {
										"type": "string",
										"enum": [
											"start",
											"center",
											"end",
											"between",
											"around",
											"evenly"
										]
									},
									"align": {
										"type": "string",
										"enum": ["start", "center", "end", "stretch", "baseline"]
									},
									"gap": {
										"type": "integer",
										"minimum": 0,
										"maximum": 12
									},
									"wrap": { "type": "boolean" }
								}
							}
						}
					}
				},
				{
					"if": { "properties": { "kind": { "const": "checkboxlist" } } },
					"then": {
						"properties": {
							"options": {
								"required": ["options"],
								"properties": {
									"options": { "$ref": "#/$defs/choiceOptions" }
								}
							}
						}
					}
				},
				{
					"if": { "properties": { "kind": { "const": "togglebuttons" } } },
					"then": {
						"properties": {
							"options": {
								"required": ["options"],
								"properties": {
									"options": { "$ref": "#/$defs/choiceOptions" },
									"multiple": { "type": "boolean" }
								}
							}
						}
					}
				},
				{
					"if": { "properties": { "kind": { "const": "slider" } } },
					"then": {
						"properties": {
							"options": {
								"properties": {
									"min": { "type": "number" },
									"max": { "type": "number" },
									"step": { "type": "number" }
								}
							}
						}
					}
				}
			]
		},
		"containerOptions": {
			"type": "object",
			"properties": {
				"children": { "type": "array", "items": { "$ref": "#/$defs/node" } },
				"fields": { "type": "array", "items": { "$ref": "#/$defs/node" } },
				"params": { "type": "array", "items": { "$ref": "#/$defs/node" } },
				"filters": { "type": "array", "items": { "$ref": "#/$defs/node" } },
				"rowActions": { "type": "array", "items": { "$ref": "#/$defs/node" } },
				"bulkActions": { "type": "array", "items": { "$ref": "#/$defs/node" } },
				"tabs": {
					"type": "array",
					"items": {
						"oneOf": [
							{
								"type": "object",
								"required": ["label", "body"],
								"properties": {
									"label": { "type": "string" },
									"body": { "$ref": "#/$defs/node" }
								}
							},
							{ "$ref": "#/$defs/tableTab" }
						]
					}
				},
				"constraints": { "$ref": "#/$defs/constraints" },
				"label": { "type": "string" },
				"helperText": { "type": "string" },
				"tooltip": { "type": "string" },
				"collapsed": { "type": "boolean" },
				"create": {
					"type": "object",
					"required": ["fields"],
					"properties": {
						"fields": { "type": "array", "items": { "$ref": "#/$defs/node" } }
					},
					"additionalProperties": false
				}
			}
		},
		"columns": {
			"type": "array",
			"items": {
				"type": "object",
				"required": ["name"],
				"properties": {
					"name": { "type": "string" },
					"label": { "type": "string" },
					"kind": { "type": "string" },
					"sortable": { "type": "boolean" },
					"searchable": { "type": "boolean" },
					"toggleable": { "type": "boolean" },
					"hiddenByDefault": { "type": "boolean" },
					"align": { "type": "string", "enum": ["left", "center", "right"] },
					"icon": {
						"type": "object",
						"required": ["name", "position"],
						"properties": {
							"name": { "type": "string" },
							"position": { "type": "string", "enum": ["left", "right"] }
						}
					},
					"width": { "type": "string" },
					"wrap": { "type": "boolean" },
					"tooltip": { "type": "string" },
					"translatable": { "type": "boolean" },
					"format": { "type": "string" },
					"decimals": { "type": "integer" },
					"currency": { "type": "string" },
					"badge": {
						"type": "object",
						"properties": {
							"colors": { "type": "object" }
						}
					},
					"boolean": {
						"type": "object",
						"properties": {
							"trueIcon": { "type": "string" },
							"falseIcon": { "type": "string" },
							"trueColor": { "type": "string" },
							"falseColor": { "type": "string" }
						}
					},
					"iconMap": { "type": "object" },
					"editable": {
						"type": "object",
						"required": ["as"],
						"properties": {
							"as": { "type": "string", "enum": ["boolean", "text", "select"] },
							"constraints": { "$ref": "#/$defs/constraints" },
							"options": {
								"type": "array",
								"items": {
									"type": "object",
									"required": ["value", "label"],
									"properties": {
										"value": { "type": "string" },
										"label": { "type": "string" }
									}
								}
							}
						},
						"additionalProperties": false
					}
				}
			}
		},
		"tableTab": {
			"type": "object",
			"required": ["name", "label", "count"],
			"properties": {
				"name": { "type": "string", "minLength": 1 },
				"label": { "type": "string" },
				"count": { "type": "boolean" }
			},
			"additionalProperties": false
		},
		"pagination": {
			"type": "object",
			"required": ["perPage", "options"],
			"properties": {
				"perPage": { "type": "integer", "minimum": 1 },
				"options": {
					"type": "array",
					"items": { "type": "integer", "minimum": 1 }
				}
			}
		},
		"choiceOptions": {
			"type": "array",
			"items": {
				"type": "object",
				"required": ["value", "label"],
				"properties": {
					"value": { "type": "string" },
					"label": { "type": "string" }
				}
			}
		},
		"constraints": {
			"type": "object",
			"properties": {
				"required": { "type": "boolean" },
				"min": { "type": "number" },
				"max": { "type": "number" },
				"email": { "type": "boolean" },
				"url": { "type": "boolean" },
				"integer": { "type": "boolean" },
				"regex": { "type": "string" },
				"in": { "type": "array", "items": { "type": "string" } }
			},
			"additionalProperties": false
		},
		"actionSpec": {
			"oneOf": [
				{
					"type": "object",
					"required": ["type", "href"],
					"properties": {
						"type": { "const": "visit" },
						"href": { "type": "string" }
					},
					"additionalProperties": false
				},
				{
					"type": "object",
					"required": ["type"],
					"properties": {
						"type": { "const": "submit" },
						"form": { "type": "string" }
					},
					"additionalProperties": false
				},
				{
					"type": "object",
					"required": ["type", "needs"],
					"properties": {
						"type": { "const": "server" },
						"needs": {
							"type": "array",
							"items": { "enum": ["form", "row", "selection"] }
						}
					},
					"additionalProperties": false
				},
				{
					"type": "object",
					"required": ["type", "title"],
					"properties": {
						"type": { "const": "modal" },
						"title": { "type": "string" },
						"description": { "type": "string" },
						"body": { "$ref": "#/$defs/node" },
						"size": { "type": "string", "enum": ["sm", "md", "lg", "full"] },
						"query": { "type": "boolean" },
						"queryNeeds": {
							"type": "array",
							"items": { "enum": ["form", "row", "selection"] }
						}
					},
					"additionalProperties": false
				},
				{
					"type": "object",
					"required": ["type", "handler", "params"],
					"properties": {
						"type": { "const": "custom" },
						"handler": { "type": "string" },
						"params": { "type": "object" }
					},
					"additionalProperties": false
				}
			]
		},
		"condition": {
			"oneOf": [
				{
					"type": "object",
					"required": ["op", "field"],
					"properties": {
						"op": {
							"enum": [
								"eq",
								"neq",
								"in",
								"notIn",
								"empty",
								"notEmpty",
								"truthy",
								"gt",
								"gte",
								"lt",
								"lte"
							]
						},
						"field": { "type": "string" },
						"value": {}
					},
					"additionalProperties": false
				},
				{
					"type": "object",
					"required": ["op", "conds"],
					"properties": {
						"op": { "enum": ["all", "any"] },
						"conds": {
							"type": "array",
							"items": { "$ref": "#/$defs/condition" }
						}
					},
					"additionalProperties": false
				},
				{
					"type": "object",
					"required": ["op", "cond"],
					"properties": {
						"op": { "const": "not" },
						"cond": { "$ref": "#/$defs/condition" }
					},
					"additionalProperties": false
				},
				{
					"type": "object",
					"required": ["op"],
					"properties": {
						"op": { "const": "server" }
					},
					"additionalProperties": false
				}
			]
		},
		"chrome": {
			"type": "object",
			"required": ["header", "sidebar", "footer"],
			"properties": {
				"header": { "oneOf": [{ "$ref": "#/$defs/node" }, { "type": "null" }] },
				"sidebar": { "oneOf": [{ "$ref": "#/$defs/node" }, { "type": "null" }] },
				"footer": { "oneOf": [{ "$ref": "#/$defs/node" }, { "type": "null" }] }
			},
			"additionalProperties": false
		},
		"effects": {
			"type": "array",
			"items": {
				"oneOf": [
					{
						"type": "object",
						"required": ["kind", "message"],
						"properties": {
							"kind": { "const": "notify" },
							"message": { "type": "string" },
							"level": { "enum": ["info", "success", "error", "warning"] }
						},
						"additionalProperties": false
					},
					{
						"type": "object",
						"required": ["kind", "href"],
						"properties": {
							"kind": { "const": "redirect" },
							"href": { "type": "string" }
						},
						"additionalProperties": false
					},
					{
						"type": "object",
						"required": ["kind"],
						"properties": {
							"kind": { "const": "refreshTable" },
							"table": { "type": "string" }
						},
						"additionalProperties": false
					},
					{
						"type": "object",
						"required": ["kind"],
						"properties": {
							"kind": { "const": "resetForm" },
							"form": { "type": "string" }
						},
						"additionalProperties": false
					},
					{
						"type": "object",
						"required": ["kind"],
						"properties": { "kind": { "const": "closeModal" } },
						"additionalProperties": false
					}
				]
			}
		}
	}
}

{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"$id": "https://tbtop.dev/contracts/structure.schema.json",
	"version": 1,
	"title": "Tabletop wire structure grammar v1",
	"$ref": "#/$defs/node",
	"$defs": {
		"node": {
			"type": "object",
			"required": ["kind", "options", "meta"],
			"properties": {
				"kind": { "type": "string", "minLength": 1 },
				"name": { "type": "string" },
				"options": { "$ref": "#/$defs/containerOptions" },
				"meta": {
					"type": "object",
					"properties": {
						"hiddenIf": { "$ref": "#/$defs/condition" },
						"disabledIf": { "$ref": "#/$defs/condition" }
					}
				}
			},
			"additionalProperties": false,
			"allOf": [
				{
					"if": { "properties": { "kind": { "const": "action" } } },
					"then": {
						"properties": {
							"options": {
								"required": ["spec"],
								"properties": {
									"spec": { "$ref": "#/$defs/actionSpec" },
									"icon": { "$ref": "#/$defs/icon" },
									"tooltip": { "type": "string" },
									"size": { "type": "string", "enum": ["sm", "md", "lg"] },
									"outlined": { "type": "boolean" },
									"as": { "type": "string", "enum": ["link", "button"] }
								}
							}
						}
					}
				},
				{
					"if": { "properties": { "kind": { "const": "form" } } },
					"then": {
						"properties": {
							"options": { "required": ["name", "children"] }
						}
					}
				},
				{
					"if": { "properties": { "kind": { "const": "table" } } },
					"then": {
						"properties": {
							"options": {
								"required": ["name", "columns"],
								"properties": {
									"columns": { "$ref": "#/$defs/columns" },
									"pagination": { "$ref": "#/$defs/pagination" },
									"rowClick": { "type": "string" },
									"reorder": {
										"type": "object",
										"required": ["column"],
										"properties": {
											"column": { "type": "string" }
										},
										"additionalProperties": false
									},
									"tabs": {
										"type": "array",
										"items": { "$ref": "#/$defs/tableTab" }
									},
									"searchPlaceholder": { "type": "string" },
									"emptyState": {
										"type": "object",
										"properties": {
											"heading": { "type": "string" },
											"description": { "type": "string" },
											"icon": { "type": "string" }
										}
									},
									"headerActions": { "type": "array", "items": { "$ref": "#/$defs/node" } },
									"embedded": { "type": "boolean" },
									"toolbar": { "type": "boolean" },
									"searchInput": { "type": "boolean" },
									"columnToggle": { "type": "boolean" },
									"recordUrl": { "type": "boolean" },
									"recordUrlNewTab": { "type": "boolean" },
									"deferFilters": { "type": "boolean" },
									"filtersFormColumns": { "type": "integer" },
									"filtersFormWidth": { "type": "string", "enum": ["sm", "md", "lg", "full"] },
									"groups": {
										"type": "object",
										"required": ["column"],
										"properties": {
											"column": { "type": "string" }
										},
										"additionalProperties": false
									}
								}
							}
						}
					}
				},
				{
					"if": { "properties": { "kind": { "const": "collapsible" } } },
					"then": {
						"properties": {
							"options": {
								"required": ["label"],
								"properties": {
									"label": { "type": "string" },
									"collapsed": { "type": "boolean" }
								}
							}
						}
					}
				},
				{
					"if": { "properties": { "kind": { "const": "actionGroup" } } },
					"then": {
						"properties": {
							"options": {
								"required": ["label"],
								"properties": {
									"label": { "type": "string" },
									"as": { "type": "string", "enum": ["buttons", "dropdown"] }
								}
							}
						}
					}
				},
				{
					"if": { "properties": { "kind": { "const": "mediaLibrary" } } },
					"then": {
						"properties": {
							"options": { "type": "object" }
						}
					}
				},
				{
					"if": { "properties": { "kind": { "const": "media" } } },
					"then": {
						"properties": {
							"options": {
								"properties": {
									"multiple": { "type": "boolean" },
									"accept": { "type": "array", "items": { "type": "string" } }
								}
							}
						}
					}
				},
				{
					"if": { "properties": { "kind": { "const": "upload" } } },
					"then": {
						"properties": {
							"options": {
								"properties": {
									"accept": { "type": "string" },
									"maxSize": { "type": "integer", "minimum": 0 },
									"multiple": { "type": "boolean" },
									"maxFiles": { "type": "integer", "minimum": 1 },
									"reorderable": { "type": "boolean" },
									"disk": { "type": "string" },
									"directory": { "type": "string" },
									"profile": { "type": "string" },
									"visibility": {
										"type": "string",
										"enum": ["public", "private"]
									},
									"image": {
										"type": "object",
										"properties": {
											"convertTo": {
												"type": "string",
												"enum": ["webp", "jpeg", "png"]
											},
											"quality": {
												"type": "integer",
												"minimum": 1,
												"maximum": 100
											}
										}
									}
								}
							}
						}
					}
				},
				{
					"if": {
						"properties": {
							"kind": {
								"enum": ["navMenu", "userMenu", "logo", "spacer", "notifications"]
							}
						}
					},
					"then": {
						"properties": {
							"options": {
								"additionalProperties": false,
								"properties": {}
							}
						}
					}
				},
				{
					"if": { "properties": { "kind": { "const": "localeSwitcher" } } },
					"then": {
						"properties": {
							"options": {
								"additionalProperties": false,
								"properties": {
									"variant": { "type": "string", "enum": ["buttons", "dropdown"] }
								}
							}
						}
					}
				},
				{
					"if": {
						"properties": { "kind": { "const": "flex" } }
					},
					"then": {
						"properties": {
							"options": {
								"required": ["direction", "children"],
								"properties": {
									"direction": {
										"type": "string",
										"enum": ["row", "col"]
									},
									"justify": {
										"type": "string",
										"enum": [
											"start",
											"center",
											"end",
											"between",
											"around",
											"evenly"
										]
									},
									"align": {
										"type": "string",
										"enum": ["start", "center", "end", "stretch", "baseline"]
									},
									"gap": {
										"type": "integer",
										"minimum": 0,
										"maximum": 12
									},
									"wrap": { "type": "boolean" }
								}
							}
						}
					}
				},
				{
					"if": { "properties": { "kind": { "const": "checkboxlist" } } },
					"then": {
						"properties": {
							"options": {
								"required": ["options"],
								"properties": {
									"options": { "$ref": "#/$defs/choiceOptions" }
								}
							}
						}
					}
				},
				{
					"if": { "properties": { "kind": { "const": "togglebuttons" } } },
					"then": {
						"properties": {
							"options": {
								"required": ["options"],
								"properties": {
									"options": { "$ref": "#/$defs/choiceOptions" },
									"multiple": { "type": "boolean" }
								}
							}
						}
					}
				},
				{
					"if": { "properties": { "kind": { "const": "slider" } } },
					"then": {
						"properties": {
							"options": {
								"properties": {
									"min": { "type": "number" },
									"max": { "type": "number" },
									"step": { "type": "number" }
								}
							}
						}
					}
				},
				{
					"if": { "properties": { "kind": { "const": "displayValue" } } },
					"then": {
						"properties": {
							"options": {
								"required": ["value"],
								"additionalProperties": false,
								"properties": {
									"value": {},
									"kind": {
										"type": "string",
										"enum": [
											"badge",
											"boolean",
											"icon",
											"money",
											"date",
											"datetime",
											"number"
										]
									},
									"badge": {
										"type": "object",
										"properties": { "colors": { "type": "object" } }
									},
									"boolean": {
										"type": "object",
										"properties": {
											"trueIcon": { "type": "string" },
											"falseIcon": { "type": "string" },
											"trueColor": { "type": "string" },
											"falseColor": { "type": "string" }
										}
									},
									"iconMap": { "type": "object" },
									"field": { "type": "string" },
									"copyable": {
										"type": "object",
										"properties": {
											"message": { "type": "string" },
											"duration": { "type": "integer" }
										}
									}
								}
							}
						}
					}
				},
				{
					"if": { "properties": { "kind": { "const": "displayImage" } } },
					"then": {
						"properties": {
							"options": {
								"required": ["src"],
								"additionalProperties": false,
								"properties": {
									"src": { "type": "string" },
									"alt": { "type": "string" },
									"caption": { "type": "string" },
									"asLink": { "type": "boolean" },
									"shape": { "type": "string", "enum": ["square", "circular"] }
								}
							}
						}
					}
				},
				{
					"if": { "properties": { "kind": { "const": "displayRichtext" } } },
					"then": {
						"properties": {
							"options": {
								"required": ["state"],
								"additionalProperties": false,
								"properties": {
									"state": { "type": "object" }
								}
							}
						}
					}
				},
				{
					"if": { "properties": { "kind": { "const": "displayKeyValue" } } },
					"then": {
						"properties": {
							"options": {
								"required": ["entries"],
								"additionalProperties": false,
								"properties": {
									"entries": { "type": "object" }
								}
							}
						}
					}
				},
				{
					"if": { "properties": { "kind": { "const": "grid" } } },
					"then": {
						"properties": {
							"options": {
								"properties": {
									"cols": { "$ref": "#/$defs/columnsSpec" }
								}
							}
						}
					}
				},
				{
					"if": { "properties": { "kind": { "const": "section" } } },
					"then": {
						"properties": {
							"options": {
								"properties": {
									"title": { "type": "string" },
									"description": { "type": "string" },
									"icon": { "$ref": "#/$defs/icon" },
									"aside": { "$ref": "#/$defs/node" },
									"collapsible": { "type": "boolean" },
									"collapsed": { "type": "boolean" },
									"columns": { "$ref": "#/$defs/columnsSpec" },
									"action": {
										"type": "object",
										"required": ["label", "url"],
										"properties": {
											"label": { "type": "string" },
											"url": { "type": "string" }
										},
										"additionalProperties": false
									},
									"variant": { "type": "string", "enum": ["card", "plain"] }
								}
							}
						}
					}
				},
				{
					"if": { "properties": { "kind": { "const": "row" } } },
					"then": {
						"properties": {
							"options": {
								"properties": {
									"variant": { "type": "string", "enum": ["grid"] }
								}
							}
						}
					}
				},
				{
					"if": { "properties": { "kind": { "const": "list" } } },
					"then": {
						"properties": {
							"options": {
								"required": ["items"],
								"properties": {
									"items": {
										"type": "array",
										"items": { "$ref": "#/$defs/listItem" }
									}
								}
							}
						}
					}
				},
				{
					"if": { "properties": { "kind": { "const": "stat" } } },
					"then": {
						"properties": {
							"options": {
								"required": ["label"],
								"properties": {
									"label": { "type": "string" },
									"value": {},
									"description": { "type": "string" },
									"descriptionColor": {
										"type": "string",
										"enum": ["success", "warning", "danger"]
									},
									"trend": { "type": "string", "enum": ["up", "down"] },
									"delta": {
										"type": "object",
										"required": ["text", "direction"],
										"properties": {
											"text": { "type": "string" },
											"direction": { "type": "string", "enum": ["up", "down", "flat"] }
										},
										"additionalProperties": false
									},
									"color": { "type": "string" },
									"sparkline": { "type": "array", "items": { "type": "number" } },
									"sparklinePosition": { "type": "string", "enum": ["inline", "bottom"] },
									"sparklineColor": {
										"type": "string",
										"enum": ["success", "warning", "danger", "primary"]
									},
									"poll": { "type": "integer", "minimum": 5 },
									"source": { "type": "string" },
									"icon": { "$ref": "#/$defs/icon" },
									"tooltip": { "type": "string" }
								}
							}
						}
					}
				},
				{
					"if": { "properties": { "kind": { "type": "string", "pattern": "^chart:" } } },
					"then": {
						"properties": {
							"options": {
								"properties": {
									"type": { "type": "string" },
									"source": { "type": "string" },
									"poll": { "type": "integer", "minimum": 5 }
								}
							}
						}
					}
				},
				{
					"if": { "properties": { "kind": { "const": "radio" } } },
					"then": {
						"properties": {
							"options": {
								"properties": {
									"options": { "$ref": "#/$defs/choiceOptions" },
									"inline": { "type": "boolean" }
								}
							}
						}
					}
				}
			]
		},
		"containerOptions": {
			"type": "object",
			"properties": {
				"children": { "type": "array", "items": { "$ref": "#/$defs/node" } },
				"fields": { "type": "array", "items": { "$ref": "#/$defs/node" } },
				"params": { "type": "array", "items": { "$ref": "#/$defs/node" } },
				"filters": { "type": "array", "items": { "$ref": "#/$defs/node" } },
				"rowActions": { "type": "array", "items": { "$ref": "#/$defs/node" } },
				"bulkActions": { "type": "array", "items": { "$ref": "#/$defs/node" } },
				"tabs": {
					"type": "array",
					"items": {
						"oneOf": [
							{
								"type": "object",
								"required": ["label", "body"],
								"properties": {
									"label": { "type": "string" },
									"body": { "$ref": "#/$defs/node" },
									"icon": { "$ref": "#/$defs/icon" },
									"badge": { "type": "string" }
								}
							},
							{ "$ref": "#/$defs/tableTab" }
						]
					}
				},
				"constraints": { "$ref": "#/$defs/constraints" },
				"label": { "type": "string" },
				"helperText": { "type": "string" },
				"tooltip": { "type": "string" },
				"copyable": {
					"type": "object",
					"properties": {
						"message": { "type": "string" },
						"duration": { "type": "integer" }
					}
				},
				"mask": { "type": "string" },
				"collapsed": { "type": "boolean" },
				"dependsOn": { "type": "array", "items": { "type": "string" } },
				"keepValue": { "type": "boolean" },
				"whenParentEmpty": { "type": "string", "enum": ["disabled", "empty"] },
				"colSpan": { "$ref": "#/$defs/columnsSpec" },
				"colStart": { "$ref": "#/$defs/columnsSpec" },
				"create": {
					"type": "object",
					"required": ["fields"],
					"properties": {
						"fields": { "type": "array", "items": { "$ref": "#/$defs/node" } }
					},
					"additionalProperties": false
				}
			}
		},
		"columnsSpec": {
			"oneOf": [
				{ "type": "integer", "minimum": 1, "maximum": 8 },
				{
					"type": "object",
					"properties": {
						"sm": { "type": "integer", "minimum": 1, "maximum": 8 },
						"md": { "type": "integer", "minimum": 1, "maximum": 8 },
						"lg": { "type": "integer", "minimum": 1, "maximum": 8 },
						"xl": { "type": "integer", "minimum": 1, "maximum": 8 }
					},
					"additionalProperties": false
				}
			]
		},
		"columns": {
			"type": "array",
			"items": {
				"type": "object",
				"required": ["name"],
				"properties": {
					"name": { "type": "string" },
					"label": { "type": "string" },
					"kind": { "type": "string" },
					"sortable": { "type": "boolean" },
					"searchable": { "type": "boolean" },
					"columnSearchable": { "type": "boolean" },
					"toggleable": { "type": "boolean" },
					"hiddenByDefault": { "type": "boolean" },
					"align": { "type": "string", "enum": ["left", "center", "right"] },
					"icon": { "$ref": "#/$defs/icon" },
					"width": { "type": "string" },
					"wrap": { "type": "boolean" },
					"tooltip": { "type": "string" },
					"copyable": {
						"type": "object",
						"properties": {
							"message": { "type": "string" },
							"duration": { "type": "integer" }
						}
					},
					"translatable": { "type": "boolean" },
					"format": { "type": "string" },
					"decimals": { "type": "integer" },
					"currency": { "type": "string" },
					"badge": {
						"type": "object",
						"properties": {
							"colors": { "type": "object" }
						}
					},
					"boolean": {
						"type": "object",
						"properties": {
							"trueIcon": { "type": "string" },
							"falseIcon": { "type": "string" },
							"trueColor": { "type": "string" },
							"falseColor": { "type": "string" }
						}
					},
					"iconMap": { "type": "object" },
					"shape": { "type": "string", "enum": ["square", "circular", "rounded"] },
					"alt": { "type": "string" },
					"link": {
						"type": "object",
						"properties": {
							"external": { "type": "boolean" },
							"icon": { "type": "string" }
						}
					},
					"editable": {
						"type": "object",
						"required": ["as"],
						"properties": {
							"as": { "type": "string", "enum": ["boolean", "text", "select"] },
							"constraints": { "$ref": "#/$defs/constraints" },
							"options": {
								"type": "array",
								"items": {
									"type": "object",
									"required": ["value", "label"],
									"properties": {
										"value": { "type": "string" },
										"label": { "type": "string" }
									}
								}
							}
						},
						"additionalProperties": false
					}
				}
			}
		},
		"icon": {
			"type": "object",
			"required": ["name", "position"],
			"properties": {
				"name": { "type": "string" },
				"position": { "type": "string", "enum": ["left", "right"] }
			},
			"additionalProperties": false
		},
		"navItem": {
			"type": "object",
			"required": ["label", "href", "order"],
			"properties": {
				"label": { "type": "string" },
				"href": { "type": "string" },
				"order": { "type": "integer" },
				"icon": { "$ref": "#/$defs/icon" },
				"badge": { "type": "string" },
				"badgeColor": { "type": "string" },
				"newTab": { "type": "boolean" },
				"children": { "type": "array", "items": { "$ref": "#/$defs/navItem" } }
			},
			"additionalProperties": false
		},
		"navGroup": {
			"type": "object",
			"required": ["key", "group", "items"],
			"properties": {
				"key": { "type": "string" },
				"group": { "type": "string" },
				"items": { "type": "array", "items": { "$ref": "#/$defs/navItem" } },
				"icon": { "$ref": "#/$defs/icon" },
				"collapsible": { "type": "boolean" },
				"collapsed": { "type": "boolean" }
			},
			"additionalProperties": false
		},
		"userMenuItem": {
			"type": "object",
			"required": ["label", "href"],
			"properties": {
				"label": { "type": "string" },
				"href": { "type": "string" },
				"icon": { "$ref": "#/$defs/icon" },
				"newTab": { "type": "boolean" }
			},
			"additionalProperties": false
		},
		"nav": { "type": "array", "items": { "$ref": "#/$defs/navGroup" } },
		"userMenuItems": { "type": "array", "items": { "$ref": "#/$defs/userMenuItem" } },
		"listItem": {
			"type": "object",
			"required": ["title"],
			"properties": {
				"title": { "type": "string" },
				"meta": { "type": "string" },
				"color": {
					"type": "string",
					"enum": ["success", "warning", "danger", "muted"]
				},
				"url": { "type": "string" }
			},
			"additionalProperties": false
		},
		"tableTab": {
			"type": "object",
			"required": ["name", "label", "count"],
			"properties": {
				"name": { "type": "string", "minLength": 1 },
				"label": { "type": "string" },
				"count": { "type": "boolean" },
				"icon": { "$ref": "#/$defs/icon" },
				"tooltip": { "type": "string" },
				"description": { "type": "string" }
			},
			"additionalProperties": false
		},
		"pagination": {
			"type": "object",
			"required": ["perPage", "options"],
			"properties": {
				"perPage": { "type": "integer", "minimum": 1 },
				"options": {
					"type": "array",
					"items": { "type": "integer", "minimum": 1 }
				}
			}
		},
		"choiceOptions": {
			"type": "array",
			"items": {
				"type": "object",
				"required": ["value", "label"],
				"properties": {
					"value": { "type": "string" },
					"label": { "type": "string" },
					"description": { "type": "string" },
					"disabled": { "type": "boolean" }
				}
			}
		},
		"constraints": {
			"type": "object",
			"properties": {
				"required": { "type": "boolean" },
				"min": { "type": "number" },
				"max": { "type": "number" },
				"email": { "type": "boolean" },
				"url": { "type": "boolean" },
				"integer": { "type": "boolean" },
				"regex": { "type": "string" },
				"in": { "type": "array", "items": { "type": "string" } }
			},
			"additionalProperties": false
		},
		"actionSpec": {
			"oneOf": [
				{
					"type": "object",
					"required": ["type", "href"],
					"properties": {
						"type": { "const": "visit" },
						"href": { "type": "string" }
					},
					"additionalProperties": false
				},
				{
					"type": "object",
					"required": ["type"],
					"properties": {
						"type": { "const": "submit" },
						"form": { "type": "string" }
					},
					"additionalProperties": false
				},
				{
					"type": "object",
					"required": ["type", "needs"],
					"properties": {
						"type": { "const": "server" },
						"needs": {
							"type": "array",
							"items": { "enum": ["form", "row", "selection"] }
						}
					},
					"additionalProperties": false
				},
				{
					"type": "object",
					"required": ["type", "title"],
					"properties": {
						"type": { "const": "modal" },
						"title": { "type": "string" },
						"description": { "type": "string" },
						"body": { "$ref": "#/$defs/node" },
						"size": { "type": "string", "enum": ["sm", "md", "lg", "xl", "2xl", "3xl", "4xl", "5xl", "6xl", "7xl", "full"] },
						"slideOver": { "type": "boolean" },
						"query": { "type": "boolean" },
						"queryNeeds": {
							"type": "array",
							"items": { "enum": ["form", "row", "selection"] }
						}
					},
					"additionalProperties": false
				},
				{
					"type": "object",
					"required": ["type", "handler", "params"],
					"properties": {
						"type": { "const": "custom" },
						"handler": { "type": "string" },
						"params": { "type": "object" }
					},
					"additionalProperties": false
				}
			]
		},
		"condition": {
			"oneOf": [
				{
					"type": "object",
					"required": ["op", "field"],
					"properties": {
						"op": {
							"enum": [
								"eq",
								"neq",
								"in",
								"notIn",
								"empty",
								"notEmpty",
								"truthy",
								"gt",
								"gte",
								"lt",
								"lte"
							]
						},
						"field": { "type": "string" },
						"value": {}
					},
					"additionalProperties": false
				},
				{
					"type": "object",
					"required": ["op", "conds"],
					"properties": {
						"op": { "enum": ["all", "any"] },
						"conds": {
							"type": "array",
							"items": { "$ref": "#/$defs/condition" }
						}
					},
					"additionalProperties": false
				},
				{
					"type": "object",
					"required": ["op", "cond"],
					"properties": {
						"op": { "const": "not" },
						"cond": { "$ref": "#/$defs/condition" }
					},
					"additionalProperties": false
				},
				{
					"type": "object",
					"required": ["op"],
					"properties": {
						"op": { "const": "server" }
					},
					"additionalProperties": false
				}
			]
		},
		"chrome": {
			"type": "object",
			"required": ["header", "sidebar", "footer"],
			"properties": {
				"header": { "oneOf": [{ "$ref": "#/$defs/node" }, { "type": "null" }] },
				"sidebar": { "oneOf": [{ "$ref": "#/$defs/node" }, { "type": "null" }] },
				"footer": { "oneOf": [{ "$ref": "#/$defs/node" }, { "type": "null" }] }
			},
			"additionalProperties": false
		},
		"effects": {
			"type": "array",
			"items": {
				"oneOf": [
					{
						"type": "object",
						"required": ["kind", "message"],
						"properties": {
							"kind": { "const": "notify" },
							"message": { "type": "string" },
							"level": { "enum": ["info", "success", "error", "warning"] }
						},
						"additionalProperties": false
					},
					{
						"type": "object",
						"required": ["kind", "href"],
						"properties": {
							"kind": { "const": "redirect" },
							"href": { "type": "string" }
						},
						"additionalProperties": false
					},
					{
						"type": "object",
						"required": ["kind"],
						"properties": {
							"kind": { "const": "refreshTable" },
							"table": { "type": "string" }
						},
						"additionalProperties": false
					},
					{
						"type": "object",
						"required": ["kind"],
						"properties": {
							"kind": { "const": "resetForm" },
							"form": { "type": "string" }
						},
						"additionalProperties": false
					},
					{
						"type": "object",
						"required": ["kind"],
						"properties": { "kind": { "const": "closeModal" } },
						"additionalProperties": false
					},
					{
						"type": "object",
						"required": ["kind", "message"],
						"properties": {
							"kind": { "const": "haltModal" },
							"message": { "type": "string" },
							"level": { "enum": ["info", "success", "error", "warning"] }
						},
						"additionalProperties": false
					}
				]
			}
		}
	}
}

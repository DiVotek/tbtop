{
    "kind": "stack",
    "options": {
        "children": [
            {
                "kind": "displayText",
                "options": {
                    "content": "Kitchen sink",
                    "variant": "heading"
                },
                "meta": {}
            },
            {
                "kind": "displayText",
                "options": {
                    "content": "Every node kind the PHP DSL can emit.",
                    "variant": "muted"
                },
                "meta": {}
            },
            {
                "kind": "displayDivider",
                "options": {},
                "meta": {}
            },
            {
                "kind": "grid",
                "options": {
                    "cols": 2,
                    "children": [
                        {
                            "kind": "chart:line",
                            "options": {
                                "xKey": "month",
                                "source": "byMonth",
                                "type": "line"
                            },
                            "meta": {},
                            "name": "byMonth"
                        },
                        {
                            "kind": "chart:donut",
                            "options": {
                                "nameKey": "status",
                                "source": "byStatus",
                                "type": "donut"
                            },
                            "meta": {},
                            "name": "byStatus"
                        },
                        {
                            "kind": "chart:bar",
                            "options": {
                                "xKey": "period",
                                "source": "byInterval",
                                "params": [
                                    {
                                        "kind": "select",
                                        "options": {
                                            "options": [
                                                {
                                                    "value": "day",
                                                    "label": "Day"
                                                },
                                                {
                                                    "value": "week",
                                                    "label": "Week"
                                                },
                                                {
                                                    "value": "month",
                                                    "label": "Month"
                                                }
                                            ],
                                            "default": "day"
                                        },
                                        "meta": {},
                                        "name": "interval"
                                    },
                                    {
                                        "kind": "date",
                                        "options": {},
                                        "meta": {},
                                        "name": "from"
                                    }
                                ],
                                "type": "bar"
                            },
                            "meta": {},
                            "name": "byInterval"
                        }
                    ]
                },
                "meta": {}
            },
            {
                "kind": "section",
                "options": {
                    "title": "Form",
                    "children": [
                        {
                            "kind": "form",
                            "options": {
                                "name": "post",
                                "children": [
                                    {
                                        "kind": "text",
                                        "options": {
                                            "label": "Title",
                                            "required": true,
                                            "constraints": {
                                                "required": true,
                                                "max": 200
                                            }
                                        },
                                        "meta": {},
                                        "name": "title"
                                    },
                                    {
                                        "kind": "otp",
                                        "options": {
                                            "label": "Code",
                                            "length": 6
                                        },
                                        "meta": {},
                                        "name": "auth_code"
                                    },
                                    {
                                        "kind": "textarea",
                                        "options": {
                                            "label": "Body",
                                            "helperText": "Supports Markdown.",
                                            "tooltip": "Write the post body here."
                                        },
                                        "meta": {},
                                        "name": "body"
                                    },
                                    {
                                        "kind": "number",
                                        "options": {
                                            "constraints": {
                                                "integer": true,
                                                "min": 0,
                                                "max": 5
                                            }
                                        },
                                        "meta": {},
                                        "name": "rating"
                                    },
                                    {
                                        "kind": "boolean",
                                        "options": {},
                                        "meta": {},
                                        "name": "published"
                                    },
                                    {
                                        "kind": "date",
                                        "options": {},
                                        "meta": {
                                            "hiddenIf": {
                                                "op": "eq",
                                                "field": "published",
                                                "value": false
                                            }
                                        },
                                        "name": "publishedAt"
                                    },
                                    {
                                        "kind": "text",
                                        "options": {},
                                        "meta": {
                                            "hiddenIf": {
                                                "op": "neq",
                                                "field": "type",
                                                "value": "video"
                                            }
                                        },
                                        "name": "video_url"
                                    },
                                    {
                                        "kind": "text",
                                        "options": {},
                                        "meta": {
                                            "disabledIf": {
                                                "op": "all",
                                                "conds": [
                                                    {
                                                        "op": "eq",
                                                        "field": "status",
                                                        "value": "archived"
                                                    },
                                                    {
                                                        "op": "empty",
                                                        "field": "published_at"
                                                    }
                                                ]
                                            }
                                        },
                                        "name": "caption"
                                    },
                                    {
                                        "kind": "select",
                                        "options": {
                                            "options": [
                                                {
                                                    "value": "admin",
                                                    "label": "Admin"
                                                }
                                            ],
                                            "constraints": {
                                                "in": [
                                                    "admin",
                                                    "editor"
                                                ]
                                            }
                                        },
                                        "meta": {},
                                        "name": "role"
                                    },
                                    {
                                        "kind": "select",
                                        "options": {
                                            "options": [
                                                {
                                                    "value": "read",
                                                    "label": "Read"
                                                },
                                                {
                                                    "value": "write",
                                                    "label": "Write"
                                                },
                                                {
                                                    "value": "delete",
                                                    "label": "Delete"
                                                }
                                            ],
                                            "multiple": true,
                                            "create": {
                                                "fields": [
                                                    {
                                                        "kind": "text",
                                                        "options": {
                                                            "label": "Permission name",
                                                            "required": true,
                                                            "constraints": {
                                                                "required": true
                                                            }
                                                        },
                                                        "meta": {},
                                                        "name": "name"
                                                    }
                                                ]
                                            },
                                            "constraints": {
                                                "in": [
                                                    "read",
                                                    "write",
                                                    "delete"
                                                ]
                                            }
                                        },
                                        "meta": {},
                                        "name": "permissions"
                                    },
                                    {
                                        "kind": "text",
                                        "options": {
                                            "translatable": true
                                        },
                                        "meta": {},
                                        "name": "intro"
                                    },
                                    {
                                        "kind": "slug",
                                        "options": {
                                            "fromField": "title",
                                            "constraints": {
                                                "regex": "^[a-z0-9-]+$"
                                            }
                                        },
                                        "meta": {},
                                        "name": "slug"
                                    },
                                    {
                                        "kind": "richtext",
                                        "options": {
                                            "placeholder": "Start typing\u2026"
                                        },
                                        "meta": {},
                                        "name": "content"
                                    },
                                    {
                                        "kind": "relation",
                                        "options": {
                                            "labelKey": "name",
                                            "searchable": true
                                        },
                                        "meta": {},
                                        "name": "category_id"
                                    },
                                    {
                                        "kind": "repeater",
                                        "options": {
                                            "fields": [
                                                {
                                                    "kind": "text",
                                                    "options": {
                                                        "required": true,
                                                        "constraints": {
                                                            "required": true
                                                        }
                                                    },
                                                    "meta": {},
                                                    "name": "heading"
                                                },
                                                {
                                                    "kind": "textarea",
                                                    "options": {},
                                                    "meta": {},
                                                    "name": "text"
                                                }
                                            ],
                                            "constraints": {
                                                "max": 10
                                            }
                                        },
                                        "meta": {},
                                        "name": "sections"
                                    },
                                    {
                                        "kind": "row",
                                        "options": {
                                            "children": [
                                                {
                                                    "kind": "action",
                                                    "options": {
                                                        "label": "Save",
                                                        "color": "primary",
                                                        "keybinding": "mod+s",
                                                        "spec": {
                                                            "type": "submit"
                                                        }
                                                    },
                                                    "meta": {},
                                                    "name": "save"
                                                },
                                                {
                                                    "kind": "action",
                                                    "options": {
                                                        "label": "Cancel",
                                                        "spec": {
                                                            "type": "visit",
                                                            "href": "/admin/posts"
                                                        }
                                                    },
                                                    "meta": {},
                                                    "name": "cancel"
                                                }
                                            ]
                                        },
                                        "meta": {}
                                    }
                                ]
                            },
                            "meta": {},
                            "name": "post"
                        }
                    ]
                },
                "meta": {}
            },
            {
                "kind": "tabs",
                "options": {
                    "tabs": [
                        {
                            "label": "Main",
                            "body": {
                                "kind": "displayText",
                                "options": {
                                    "content": "Tab body",
                                    "variant": "subheading"
                                },
                                "meta": {}
                            }
                        }
                    ]
                },
                "meta": {}
            },
            {
                "kind": "table",
                "options": {
                    "searchable": [
                        "title"
                    ],
                    "defaultSort": {
                        "field": "views",
                        "dir": "desc"
                    },
                    "rowActions": [
                        {
                            "kind": "action",
                            "options": {
                                "label": "Edit",
                                "spec": {
                                    "type": "server",
                                    "needs": [
                                        "row"
                                    ]
                                }
                            },
                            "meta": {
                                "hiddenIf": {
                                    "op": "eq",
                                    "field": "published",
                                    "value": true
                                }
                            },
                            "name": "edit"
                        },
                        {
                            "kind": "action",
                            "options": {
                                "label": "Delete",
                                "color": "danger",
                                "confirm": {
                                    "title": "Delete?",
                                    "description": "No undo."
                                },
                                "spec": {
                                    "type": "server",
                                    "needs": [
                                        "row"
                                    ]
                                }
                            },
                            "meta": {
                                "disabledIf": {
                                    "op": "truthy",
                                    "field": "locked"
                                }
                            },
                            "name": "delete"
                        }
                    ],
                    "bulkActions": [
                        {
                            "kind": "action",
                            "options": {
                                "label": "Delete selected",
                                "spec": {
                                    "type": "server",
                                    "needs": [
                                        "selection"
                                    ]
                                }
                            },
                            "meta": {
                                "hiddenIf": {
                                    "op": "eq",
                                    "field": "role",
                                    "value": "manager"
                                }
                            },
                            "name": "bulk-delete"
                        }
                    ],
                    "tabs": [
                        {
                            "name": "all",
                            "label": "all",
                            "count": false
                        },
                        {
                            "name": "published",
                            "label": "Published",
                            "count": true
                        }
                    ],
                    "pagination": {
                        "perPage": 25,
                        "options": [
                            10,
                            25,
                            50,
                            100
                        ]
                    },
                    "name": "posts",
                    "columns": [
                        {
                            "name": "title",
                            "label": "Title",
                            "kind": "text"
                        },
                        {
                            "name": "views",
                            "label": "Views",
                            "kind": "text"
                        },
                        {
                            "name": "published",
                            "label": "Published",
                            "kind": "boolean",
                            "editable": {
                                "as": "boolean"
                            }
                        },
                        {
                            "name": "title_edit",
                            "label": "Title (editable)",
                            "kind": "text",
                            "editable": {
                                "as": "text",
                                "constraints": {
                                    "required": true,
                                    "max": 200
                                }
                            }
                        },
                        {
                            "name": "status_edit",
                            "label": "Status (editable)",
                            "kind": "select",
                            "editable": {
                                "as": "select",
                                "constraints": {
                                    "required": true,
                                    "in": [
                                        "draft",
                                        "published"
                                    ]
                                },
                                "options": [
                                    {
                                        "value": "draft",
                                        "label": "Draft"
                                    },
                                    {
                                        "value": "published",
                                        "label": "Published"
                                    }
                                ]
                            }
                        }
                    ]
                },
                "meta": {},
                "name": "posts"
            },
            {
                "kind": "row",
                "options": {
                    "children": [
                        {
                            "kind": "action",
                            "options": {
                                "label": "About",
                                "spec": {
                                    "type": "modal",
                                    "title": "About",
                                    "body": {
                                        "kind": "displayText",
                                        "options": {
                                            "content": "Modal body",
                                            "variant": "muted"
                                        },
                                        "meta": {}
                                    }
                                }
                            },
                            "meta": {},
                            "name": "info"
                        },
                        {
                            "kind": "action",
                            "options": {
                                "label": "Details",
                                "spec": {
                                    "type": "modal",
                                    "title": "Details",
                                    "description": "More info",
                                    "size": "lg"
                                }
                            },
                            "meta": {},
                            "name": "details"
                        },
                        {
                            "kind": "action",
                            "options": {
                                "label": "Copy",
                                "spec": {
                                    "type": "custom",
                                    "handler": "clipboard",
                                    "params": {
                                        "text": "hi"
                                    }
                                }
                            },
                            "meta": {},
                            "name": "copy"
                        }
                    ]
                },
                "meta": {}
            },
            {
                "kind": "collapsible",
                "options": {
                    "collapsed": false,
                    "label": "Advanced options",
                    "children": [
                        {
                            "kind": "text",
                            "options": {
                                "label": "Meta title"
                            },
                            "meta": {},
                            "name": "meta_title"
                        }
                    ]
                },
                "meta": {}
            },
            {
                "kind": "aside",
                "options": {
                    "children": [
                        {
                            "kind": "text",
                            "options": {
                                "label": "Note"
                            },
                            "meta": {},
                            "name": "sidebar_note"
                        }
                    ]
                },
                "meta": {}
            },
            {
                "kind": "actionGroup",
                "options": {
                    "label": "Publish actions",
                    "children": [
                        {
                            "kind": "action",
                            "options": {
                                "label": "Publish",
                                "spec": {
                                    "type": "visit",
                                    "href": "/admin/posts/publish"
                                }
                            },
                            "meta": {},
                            "name": "publish"
                        },
                        {
                            "kind": "action",
                            "options": {
                                "label": "Archive",
                                "spec": {
                                    "type": "server",
                                    "needs": [
                                        "row"
                                    ]
                                }
                            },
                            "meta": {},
                            "name": "archive"
                        }
                    ]
                },
                "meta": {}
            },
            {
                "kind": "flex",
                "options": {
                    "direction": "row",
                    "children": [
                        {
                            "kind": "text",
                            "options": {},
                            "meta": {},
                            "name": "flex_a"
                        },
                        {
                            "kind": "text",
                            "options": {},
                            "meta": {},
                            "name": "flex_b"
                        }
                    ],
                    "justify": "between",
                    "align": "center",
                    "gap": 4,
                    "wrap": true
                },
                "meta": {}
            },
            {
                "kind": "row",
                "options": {
                    "children": [
                        {
                            "kind": "logo",
                            "options": {},
                            "meta": {}
                        },
                        {
                            "kind": "navMenu",
                            "options": {},
                            "meta": {}
                        },
                        {
                            "kind": "spacer",
                            "options": {},
                            "meta": {}
                        },
                        {
                            "kind": "localeSwitcher",
                            "options": {},
                            "meta": {}
                        },
                        {
                            "kind": "userMenu",
                            "options": {},
                            "meta": {}
                        }
                    ]
                },
                "meta": {}
            }
        ]
    },
    "meta": {}
}

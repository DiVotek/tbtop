{
	"name": "tbtop",
	"private": true,
	"type": "module",
	"packageManager": "bun@1.3.14",
	"scripts": {
		"lint": "oxlint",
		"lint:fix": "oxlint --fix && biome check --write --linter-enabled=false",
		"format": "biome check --write --linter-enabled=false",
		"format:check": "biome check --linter-enabled=false",
		"prepare": "simple-git-hooks"
	},
	"simple-git-hooks": {
		"pre-commit": "bun x lint-staged"
	},
	"lint-staged": {
		"**/*.{ts,tsx,js,jsx}": [
			"oxlint",
			"biome check --write --linter-enabled=false --no-errors-on-unmatched"
		],
		"**/*.{json,css}": "biome check --write --linter-enabled=false --no-errors-on-unmatched"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.15",
		"lint-staged": "^17.0.4",
		"oxlint": "^1.68.0",
		"simple-git-hooks": "^2.13.1",
		"typescript": "^5.7.2"
	}
}
